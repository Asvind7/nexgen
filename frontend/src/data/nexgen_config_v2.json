                "adaptive_logic": "Analyze user proficiency based on previous 5 inputs. If proficiency < 60%, simplify language. If > 90%, introduce 'Pro-Tips' and 'Edge Cases'."
            },
            "instructional_loop": {
                "step_1": "Contextual Hook (Connect to previous lesson)",
