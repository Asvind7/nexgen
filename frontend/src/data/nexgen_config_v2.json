    "subsystem_orchestration": {
        "teacher_engine": {
            "persona_constraints": {
                "voice": "Adaptive Persona (Mentor/Rival dynamic)",
                "forbidden_behaviors": [
                    "Repetition of concepts",
                    "Generic 'Wrong' feedback",
                    "Providing full code solutions immediately"
