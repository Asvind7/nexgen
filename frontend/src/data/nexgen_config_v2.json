                "efficiency_bonus": "Award extra XP if the user uses list comprehensions or advanced syntax."
            },
            "feedback_engine": {
                "error_mapping": {
                    "SyntaxError": "Detailed breakdown of the missing character/bracket.",
                    "LogicError": "Hint-based questioning: 'Your loop runs, but is it stopping at the right time?'",
                    "OffTopic": "The 'Guardrail' response: Redirect to current module."
                }
            }
        },
        "rage_machine_protocol": {
            "state": "Passive-Background / Active-On-Trigger",
            "trigger_phrases": [
                "What is",
                "Where is",
                "Tell me about",
                "Help with"
            ],
            "execution": {
                "search_index": "Full Python Syllabus (Phases 1-3)",
                "output_style": "High-Density / Short-Form",
                "redirect_logic": "Give definition + 'Unlock this in [Phase/Week]'. Return to Teacher Engine immediately."
            }
        }
    },
